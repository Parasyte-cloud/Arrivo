# Copy to .env and fill in real values. Never commit the real .env file.

PORT=4000

# PostgreSQL connection string. Free options: neon.tech or supabase.com
# (both have a permanent free tier — no 90-day expiry like some providers).
# Format: postgresql://user:password@host:port/database
# For local testing against a Postgres running on your own machine:
# postgresql://postgres:postgres@localhost:5432/arrivo_dev
DATABASE_URL=replace_me

# https://aviationstack.com — free tier available
AVIATIONSTACK_KEY=replace_me

# https://dashboard.paystack.com/#/settings/developer — use TEST keys until you go live
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_replace_me

# Where Paystack should send the user back after checkout (a page/deep link in your app)
PAYSTACK_CALLBACK_URL=https://arrivo.app/payment/callback

# Any long random string — used to sign login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string

# OPTIONAL. Full URL (including path) to this backend's own email
# verification page, used in the "Verify Email" link sent on signup. Leave
# this commented out / unset — it now auto-detects the correct URL from
# whatever host actually received the signup request (localhost while
# developing locally, your real Render URL in production), so there's
# nothing to configure by default. Only set this if you want verification
# emails to link to a custom domain instead of the raw backend URL, e.g.:
# EMAIL_VERIFY_BASE_URL=https://api.ridearrivo.com/api/auth/verify-email
#
# IMPORTANT: if you do set this, use a real URL — NOT "replace_me" or any
# other placeholder. Unlike other keys in this file, this one is read with
# a plain `||` fallback (see routes/auth.js), so any non-empty value here,
# including a leftover placeholder, is used literally as the link.
# EMAIL_VERIFY_BASE_URL=

# https://console.twilio.com — used to send WhatsApp messages (driver/vehicle
# assignment details, flight cancellation/reschedule alerts, driver-changed
# notices). Twilio's WhatsApp Sandbox works immediately for testing (each
# recipient sends the sandbox's join code once from their own WhatsApp,
# shown on the Twilio console's WhatsApp sandbox page) — no Meta Business
# verification needed until you're ready to message people without that
# opt-in step, at which point you'd request a real WhatsApp Business number
# through Twilio and set TWILIO_WHATSAPP_FROM to it instead.
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
# Twilio's shared sandbox number — fine as-is for testing. Replace with your
# own approved WhatsApp Business number (format: whatsapp:+1XXXXXXXXXX) once
# you have one.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# https://console.cloud.google.com — a SEPARATE key from the one already
# live on ridearrivo.com's book.html (that one's a browser key restricted
# by HTTP referrer, no good here). Create a new key with "Places API" and
# "Distance Matrix API" enabled, and restrict it by server IP (under
# Credentials > your key > Application restrictions) rather than referrer,
# since there's no browser involved server-side. Powers /api/places/* and
# real distance-based fare calculation (see services/googleMaps.js).
GOOGLE_MAPS_SERVER_KEY=replace_me

# ── Google / Apple sign-in (services/oauth.js, routes/auth.js POST /google and /apple) ──
# Comma-separated list of every Google OAuth 2.0 Client ID allowed to mint
# tokens this backend accepts — one per platform, per app (rider + driver),
# so up to 6 total. Create these at https://console.cloud.google.com under
# "APIs & Services > Credentials > Create Credentials > OAuth client ID":
#   - Type "iOS" — needs each app's bundleIdentifier (com.arrivo.app / com.arrivo.driver)
#   - Type "Android" — needs each app's package name + the SHA-1 of the
#     keystore signing your build (same SHA-1 you already pulled for the
#     Google Maps API key restriction — `eas credentials` shows it)
#   - Type "Web application" — no restrictions needed; this is what makes
#     the ID-token flow work cleanly from Expo's AuthSession
# Paste the resulting client ID strings into each app's app.json under
# extra.googleOAuth, AND list every one of them here (this backend accepts
# any token whose audience matches one of these):
GOOGLE_OAUTH_CLIENT_IDS=replace_me_with_comma_separated_client_ids

# Comma-separated list of bundle IDs allowed as the audience for Apple
# identity tokens — one per app: com.arrivo.app,com.arrivo.driver
# Requires an active Apple Developer Program membership. EAS Build manages
# the "Sign In with Apple" capability/entitlement automatically once each
# app's app.json has ios.usesAppleSignIn: true (already set) — no manual
# step in the Apple Developer portal should be needed beyond having a paid
# membership on the account EAS builds under.
APPLE_BUNDLE_IDS=com.arrivo.app,com.arrivo.driver
