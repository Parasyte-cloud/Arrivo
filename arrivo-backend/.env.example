# Copy to .env and fill in real values. Never commit the real .env file.

PORT=4000

# PostgreSQL connection string. Free options: neon.tech or supabase.com
# (both have a permanent free tier — no 90-day expiry like some providers).
# Format: postgresql://user:password@host:port/database
# For local testing against a Postgres running on your own machine:
# postgresql://postgres:postgres@localhost:5432/arrivo_dev
DATABASE_URL=replace_me

# https://aviationstack.com — free tier available
AVIATIONSTACK_KEY=replace_me

# https://dashboard.paystack.com/#/settings/developer — use TEST keys until you go live
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_PUBLIC_KEY=pk_test_replace_me

# Where Paystack should send the user back after checkout (a page/deep link in your app)
PAYSTACK_CALLBACK_URL=https://arrivo.app/payment/callback

# Any long random string — used to sign login tokens. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
