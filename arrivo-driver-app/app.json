{
  "expo": {
    "name": "RideArrivo Driver",
    "slug": "arrivo-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ridearrivo-driver",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arrivo.driver",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RideArrivo Driver uses your location to match you with nearby pickups.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RideArrivo Driver uses your location — even while the app is in the background — so riders can see you en route on their live map.",
        "UIBackgroundModes": [
          "location"
        ]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyDJtWs4Rht40RU1LdMTSv9zVYTjzfQuT7o"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F4EC"
      },
      "package": "com.arrivo.driver",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCqjGI1YW4SwoPZihsnzKX9L5q3yHcxWGw"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": "https://arrivo-backend-g1ku.onrender.com",
      "googleMapsApiKey": "AIzaSyDJtWs4Rht40RU1LdMTSv9zVYTjzfQuT7o",
      "googleOAuth": {
        "iosClientId": "425853448895-muga4qe48c2aht5nep5fjftonvd0h0ub.apps.googleusercontent.com",
        "androidClientId": "425853448895-9lsh1d70engq6k1gjnkf5lqr817bj4r1.apps.googleusercontent.com",
        "webClientId": "425853448895-r6ha3gh7b4i4lcsl3lohncuk3ecblsl3.apps.googleusercontent.com"
      },
      "eas": {
        "projectId": "322115da-a006-439d-b70d-81945e02420b"
      }
    },
    "newArchEnabled": true,
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F7F4EC"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RideArrivo Driver uses your location to match you with nearby pickups.",
          "locationAlwaysAndWhenInUsePermission": "RideArrivo Driver uses your location — even while the app is in the background — so riders can see you en route on their live map.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-web-browser"
    ]
  }
}
