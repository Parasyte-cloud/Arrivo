{
  "expo": {
    "name": "Arrivo Driver",
    "slug": "arrivo-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#12123B"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arrivo.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Arrivo Driver uses your location to match you with nearby pickups.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Arrivo Driver uses your location so riders can see you en route."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#12123B"
      },
      "package": "com.arrivo.driver",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": "http://localhost:4000",
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
