{
  "expo": {
    "name": "RideArrivo",
    "slug": "arrivo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.arrivo.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RideArrivo uses your location to find nearby pickups and show your live route.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RideArrivo uses your location to track your ride in progress."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F4EC"
      },
      "package": "com.arrivo.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiBaseUrl": "https://arrivo-backend-g1ku.onrender.com",
      "googleMapsApiKey": "REPLACE_WITH_YOUR_KEY"
    },
    "newArchEnabled": true,
    "plugins": [
      "expo-font",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "RideArrivo needs camera access to scan your driver's QR code and start live tracking."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#F7F4EC"
        }
      ]
    ]
  }
}
